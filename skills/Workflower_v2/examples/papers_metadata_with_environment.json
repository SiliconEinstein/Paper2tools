{
  "environment": {
    "description": "ARM 包的运行环境配置 - 基于超导体电声耦合计算工作流",
    "python_version": "3.9+",
    "required_packages": [
      {
        "name": "numpy",
        "version": ">=1.21.0",
        "purpose": "数值计算"
      },
      {
        "name": "scipy",
        "version": ">=1.7.0",
        "purpose": "科学计算（积分、插值、优化）"
      },
      {
        "name": "matplotlib",
        "version": ">=3.4.0",
        "purpose": "数据可视化"
      }
    ],
    "optional_packages": [
      {
        "name": "ase",
        "version": ">=3.22.0",
        "purpose": "原子结构操作和可视化"
      },
      {
        "name": "pymatgen",
        "version": ">=2022.0.0",
        "purpose": "材料分析和晶体结构处理"
      },
      {
        "name": "phonopy",
        "version": ">=2.12.0",
        "purpose": "声子计算后处理"
      }
    ],
    "computational_tools": {
      "dft_codes": [
        {
          "name": "Quantum ESPRESSO",
          "version": "6.8+",
          "purpose": "DFT 电子结构计算和 DFPT 声子计算",
          "modules": ["pw.x", "ph.x", "q2r.x", "matdyn.x"],
          "typical_parameters": {
            "ecutwfc": "40-80 Ry (平面波截断能)",
            "ecutrho": "4*ecutwfc (电荷密度截断能)",
            "k_points": "12x12x12 to 36x36x36 (Monkhorst-Pack)",
            "q_points": "6x6x6 (DFPT 声子计算)",
            "conv_thr": "1e-8 Ry (自洽收敛标准)",
            "smearing": "Gaussian or Methfessel-Paxton, 0.02-0.2 eV"
          },
          "pseudopotentials": {
            "types": ["Norm-conserving", "Ultrasoft", "PAW"],
            "sources": ["SSSP library", "PSlibrary", "GBRV"]
          }
        },
        {
          "name": "VASP",
          "version": "5.4+",
          "purpose": "DFT 结构优化和电子结构计算",
          "typical_parameters": {
            "ENCUT": "400-600 eV",
            "KPOINTS": "Gamma-centered Monkhorst-Pack",
            "EDIFF": "1e-6 eV",
            "ISMEAR": "0 (Gaussian) or 1 (Methfessel-Paxton)"
          }
        }
      ],
      "analysis_tools": [
        {
          "name": "EPW",
          "version": "5.4+",
          "purpose": "电声耦合计算（Wannier 插值）",
          "dependencies": ["Quantum ESPRESSO", "Wannier90"],
          "typical_parameters": {
            "nkf": "fine k-mesh for Fermi surface (e.g., 60x60x60)",
            "nqf": "fine q-mesh for phonons (e.g., 30x30x30)"
          }
        },
        {
          "name": "Wannier90",
          "version": "3.1+",
          "purpose": "最大局域化 Wannier 函数构建",
          "dependencies": ["Quantum ESPRESSO or VASP"]
        }
      ],
      "post_processing": [
        {
          "name": "custom Python scripts",
          "purpose": "Eliashberg 函数分析、Tc 预测（Allen-Dynes 公式）"
        }
      ]
    },
    "hardware_requirements": {
      "min_memory_gb": 16,
      "recommended_memory_gb": 64,
      "min_cores": 8,
      "recommended_cores": 32,
      "gpu_required": false,
      "disk_space_gb": 50,
      "notes": "内存需求取决于 k 点网格密度和原子数；推荐使用 HPC 集群进行大规模计算"
    },
    "notes": "环境配置基于论文中报告的计算方法汇总。实际需求取决于材料体系大小和计算精度要求。"
  },
