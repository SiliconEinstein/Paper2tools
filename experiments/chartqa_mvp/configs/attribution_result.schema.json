{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chartqa-mvp/attribution-result.schema.json",
  "title": "Attribution and Verification Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "answer_id",
    "query_id",
    "final_answer",
    "claims",
    "metrics"
  ],
  "properties": {
    "answer_id": {
      "type": "string",
      "minLength": 1
    },
    "query_id": {
      "type": "string",
      "minLength": 1
    },
    "final_answer": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "text",
          "verdict",
          "evidence"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^c[0-9]+$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "verdict": {
            "type": "string",
            "enum": [
              "supported",
              "partially_supported",
              "unsupported"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "cell_id",
                "table_id",
                "row_id",
                "col_key"
              ],
              "properties": {
                "cell_id": {
                  "type": "string",
                  "minLength": 1
                },
                "table_id": {
                  "type": "string",
                  "minLength": 1
                },
                "row_id": {
                  "type": "string",
                  "minLength": 1
                },
                "col_key": {
                  "type": "string",
                  "minLength": 1
                },
                "raw_value": {}
              }
            }
          },
          "lineage": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "calc_trace": {
            "type": "string"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "faithfulness",
        "completeness",
        "unsupported_claim_ratio"
      ],
      "properties": {
        "faithfulness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "completeness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "unsupported_claim_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

