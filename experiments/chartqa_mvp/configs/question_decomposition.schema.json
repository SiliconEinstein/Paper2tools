{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chartqa-mvp/question-decomposition.schema.json",
  "title": "Question Decomposition Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query_id",
    "question",
    "constraints",
    "subtasks",
    "claims"
  ],
  "properties": {
    "query_id": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "default": "zh-CN"
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_range",
        "entities",
        "metrics",
        "units"
      ],
      "properties": {
        "time_range": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "units": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "subtasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "objective",
          "operation",
          "dependencies",
          "expected_output",
          "evidence_type"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^t[0-9]+$"
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "operation": {
            "type": "string",
            "enum": [
              "retrieve",
              "filter",
              "aggregate",
              "compare",
              "compute",
              "explain",
              "verify"
            ]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^t[0-9]+$"
            }
          },
          "expected_output": {
            "type": "string",
            "minLength": 1
          },
          "evidence_type": {
            "type": "string",
            "enum": [
              "table",
              "schema",
              "row",
              "cell",
              "aggregation"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "text",
          "claim_type",
          "required_evidence"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^c[0-9]+$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "claim_type": {
            "type": "string",
            "enum": [
              "fact",
              "comparison",
              "calculation",
              "trend"
            ]
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "table",
                "row",
                "cell",
                "lineage"
              ]
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

